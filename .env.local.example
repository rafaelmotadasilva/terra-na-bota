# ═══════════════════════════════════════
# TERRA ★ NA BOTA — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA suba .env.local para o GitHub
# ═══════════════════════════════════════

# ── Analytics ──
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=

# ── Captura de leads (escolha uma opção) ──

# Opção A: Google Sheets via Apps Script
SHEETS_WEBHOOK=

# Opção B: Mailchimp
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_SERVER=us1

# Opção C: ConvertKit / Kit
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# Opção D: Brevo
BREVO_API_KEY=
BREVO_LIST_ID=
