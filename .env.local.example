# ═══════════════════════════════════════
# TERRA ★ NA BOTA — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA suba .env.local para o GitHub
# ═══════════════════════════════════════

# ── Analytics ──
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=

# ── Vercel KV (Upstash Redis) ──
# Obtenha em: Vercel Dashboard → Storage → KV → .env.local
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ── Resend (e-mail transacional) ──
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=
# E-mail que recebe notificação de novo lead
NOTIFY_EMAIL=

# ── Captura de leads — integrações opcionais ──

# Google Sheets via Apps Script
SHEETS_WEBHOOK=

# Mailchimp
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_SERVER=us1

# ConvertKit / Kit
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# Brevo
BREVO_API_KEY=
BREVO_LIST_ID=
