# ═══════════════════════════════════════
# TERRA ★ NA BOTA — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA suba .env.local para o GitHub
# ═══════════════════════════════════════

# ── Analytics ──
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=

# ── Vercel KV (Upstash Redis) — obrigatório em produção ──
# Obtenha em: Vercel Dashboard → Storage → KV → .env.local
# Sem estas variáveis, o endpoint /api/subscribe retorna 503 em produção.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ── Resend (e-mail transacional) ──
# Obtenha em: https://resend.com/api-keys
# Domínio contato@terranabota.com.br já verificado no Resend.
RESEND_API_KEY=
# E-mail interno que recebe notificação de novo lead
NOTIFY_EMAIL=

# ── Google Sheets (opcional) ──
# Webhook de um Apps Script para espelhar leads numa planilha
SHEETS_WEBHOOK=
